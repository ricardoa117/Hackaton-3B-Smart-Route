# ============================================================
# .env.example — Copia este archivo como ".env" y rellena
# los valores reales. NUNCA subas el .env a Git.
# ============================================================

# Token público de Mapbox (empieza con pk.)
# Obténlo en: https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=pk.tu_token_de_mapbox_aqui

# Tiempo límite en segundos para el solver OR-Tools (default: 30)
SOLVER_TIME_LIMIT_SECONDS=30

# Orígenes permitidos en CORS (separados por coma)
# Ejemplo local: http://localhost:5500,http://127.0.0.1:5500
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
